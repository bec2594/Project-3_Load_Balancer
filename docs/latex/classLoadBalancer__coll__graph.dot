digraph "LoadBalancer"
{
 // LATEX_PDF_SIZE
  edge [fontname="Helvetica",fontsize="10",labelfontname="Helvetica",labelfontsize="10"];
  node [fontname="Helvetica",fontsize="10",shape=record];
  Node1 [label="LoadBalancer",height=0.2,width=0.4,color="black", fillcolor="grey75", style="filled", fontcolor="black",tooltip="Coordinates a pool of WebServer instances by accepting Requests, filtering blocked IPs,..."];
  Node2 -> Node1 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" config" ];
  Node2 [label="Config",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$classConfig.html",tooltip="Holds configuration parameters for the load balancer simulation."];
  Node3 -> Node1 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" log_file" ];
  Node3 [label="LogFileStats",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$classLogFileStats.html",tooltip="Aggregates counters and timing metrics for the simulation and produces a summary report...."];
}
